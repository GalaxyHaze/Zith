public:

enum Color {
    blue = 0,
    red = 1,
    green = 2,
    black = 3,
    gray = 4
}

noreturn fn render(col: Color){
    switch (col){
        case blue:
        case red:
        case green:
        case black:
        case gray:
        default:
            abort("Invalid state of enum Color, what hell you did?");
    }
}

struct Point{
    public:
    x: u32;
    y: u32;

    private fn collide(self: Point, other: Point){
        if (self.x == other.x) and (self.y == other.y)
            return true;
        return false;
    }

    fn move(self: Point, vec: Vector){
        self.x += vec->x();
        self.y += vec->y();
    }

}

